# ==========================================================
# Sports Content Agent — Environment Variables
# ==========================================================
# 1. Copy this file to `.env` (same directory)
# 2. Replace placeholders with your real values
# 3. NEVER commit `.env` to git
# ==========================================================

# ----- LLM Provider (DeepSeek) -----
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-请替换成你的真实key

# ----- Model Selection -----
# DeepSeek 当前公开模型：
#   deepseek-chat  → 通用对话，适合实时评论生成（推荐）
#   deepseek-reasoner → 强推理，适合复杂分析（贵且慢，按需用）
LLM_MODEL_FAST=deepseek-chat
LLM_MODEL_REASONING=deepseek-reasoner

# ----- Generation Defaults -----
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=400
# Long tactical reports are generated as a multi-step pipeline rather than one huge JSON request.
LLM_TIMEOUT_SECONDS=60

# ----- Real-time Pipeline -----
REPLAY_SPEED=1.0          # 1.0 = 真实速度；2.0 = 加倍快放（开发时方便）
COMMENTARY_INTERVAL_SECONDS=20   # 每多少秒最多生成一条评论
ENABLE_FACT_CHECK=1       # 1 = 开启实时事实校验，0 = 关闭

# ----- Optional Vision Provider (Video Scout Agent) -----
# The Video Scout demo can run without these. Configure them only when you
# want frame images to be inspected by an OpenAI-compatible vision model.
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini
VISION_TIMEOUT_SECONDS=30

# ----- Storage Paths -----
DATA_DIR=data
KNOWLEDGE_DB_PATH=data/knowledge/sports_facts.sqlite3
TEXT_RAG_DIR=data/knowledge/documents
GENERATED_DIR=data/generated

# ----- Webapp -----
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=8765

# ----- Logging -----
LOG_LEVEL=INFO
